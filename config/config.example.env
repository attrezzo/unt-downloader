# unt-downloader configuration
# Copy to secrets.env and fill in values. Never commit secrets.env.

# --- Anthropic API ---
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-opus-4-5

# --- UNT Portal ---
UNT_BASE_URL=https://texashistory.unt.edu
UNT_COLLECTION=BWOC   # Bellville Wochenblatt collection ID

# --- Pipeline behavior ---
# Plain text is extracted from OCR before translation to avoid HTML token bloat
TRANSLATE_CHUNK_SIZE=2000     # characters per translation chunk
TRANSLATE_DELAY_MS=500        # ms between API calls to avoid rate limits

# --- OCR Correction ---
# Set to 1 to skip OCR correction stage (faster/cheaper, lower quality)
SKIP_OCR_CORRECT=0

# --- Output ---
OUTPUT_DIR=./output
LOG_DIR=./logs
LOG_LEVEL=INFO                # DEBUG, INFO, WARNING, ERROR
